{
  "url": "https://example.com/signup",
  "acceptConsent": true,
  "consentSelectors": [],
  "inputs": [
    { "selector": "input[name=email]", "value": "canary@example.com", "category": "email", "label": "signup-email" },
    { "selector": "input[type=password]", "value": "S3cr3t-Canary!", "category": "password", "label": "signup-password" }
  ],
  "secrets": [],
  "submit": "button[type=submit]",
  "settle": 4000,
  "headless": true,
  "failOn": "error",
