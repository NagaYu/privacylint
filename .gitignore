node_modules/
.pnp/
.pnp.js
.yarn/
jspm_packages/

# ---------------------------------------------------------------------------
# Build output
# ---------------------------------------------------------------------------
dist/
build/
out/
*.tsbuildinfo
.tscache/

# ---------------------------------------------------------------------------
# Secrets & environment — NEVER commit credentials or canary configuration
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
credentials.json

# ---------------------------------------------------------------------------
# Audit artifacts & captured traffic — may contain sensitive payloads
# ---------------------------------------------------------------------------
privacy-report.json
privacy-report.*.json
audit-logs/
*.audit.json
*.har
captured-requests/
scan-output/
reports/

# ---------------------------------------------------------------------------
# Playwright
# ---------------------------------------------------------------------------
playwright-report/
test-results/
.playwright/
playwright/.cache/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------------------------
# Coverage & test
# ---------------------------------------------------------------------------
coverage/
.nyc_output/

# ---------------------------------------------------------------------------
# Local tooling / agent settings (keep local permission grants out of git)
# ---------------------------------------------------------------------------
.claude/settings.local.json

# ---------------------------------------------------------------------------
# Editor / OS noise
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Caches
# ---------------------------------------------------------------------------
.npm/
.eslintcache
.cache/
tmp/
temp/
